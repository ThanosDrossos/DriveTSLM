# Copy to .env and fill in. Never commit .env.

# Anthropic API key for the agent (both analysis arms + consistency checker)
ANTHROPIC_API_KEY=sk-ant-...

# Model used by the agent and baseline arms (any current Claude model id)
CLAUDE_MODEL=claude-sonnet-5

# HuggingFace token with the VZCrash gate accepted
# (https://huggingface.co/datasets/vzc-research-chapter/VZCrash)
# Only needed to (re)build the working set; the app itself runs from the local cache.
HF_TOKEN=hf_...

# Password for the demo app gate
DEMO_PASSWORD=change-me
