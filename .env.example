# Copy to .env and fill in. Never commit .env.

# KIT AI Toolbox API key (OpenAI-compatible endpoint)
# Get one at https://ki-toolbox.scc.kit.edu -> Settings -> Account -> Create API Key
OPENAI_API_KEY=

# OpenAI-compatible base URL (any provider works; defaults to the KIT toolbox)
OPENAI_BASE_URL=https://ki-toolbox.scc.kit.edu/api/v1

# Default model for agent runs (overridable per run in the UI / CLI / eval).
# Must be one of the curated ids in backend/app/llm.py.
DEFAULT_MODEL=azure.gpt-5-mini

# HuggingFace token with the VZCrash gate accepted
# (https://huggingface.co/datasets/vzc-research-chapter/VZCrash)
# Only needed to (re)build the working set; the app itself runs from the local cache.
HF_TOKEN=

# Password for the demo app gate
DEMO_PASSWORD=change-me
